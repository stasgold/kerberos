<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- ── Top section (fixed) ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">
    <!-- ── Title ──────────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:text="@string/app_name"
            android:textColor="@color/primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Scanning status pill -->
        <TextView
            android:id="@+id/tvScanStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:paddingVertical="4dp"
            android:text="● STOPPED"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- ── Lab ID selection ─────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvLabLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.08"
            android:text="@string/label_lab_id"
            android:textAllCaps="true"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <AutoCompleteTextView
            android:id="@+id/etLabId"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@color/surface"
            android:completionThreshold="1"
            android:dropDownAnchor="@id/etLabId"
            android:dropDownWidth="match_parent"
            android:hint="@string/hint_lab_id"
            android:inputType="textCapCharacters"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />

        <!-- ── Start / Stop buttons ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary"
                android:text="@string/btn_start"
                android:textColor="@color/on_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/stop_button"
                android:text="@string/btn_stop"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ── Divider ──────────────────────────────────────────────────── -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@color/divider" />

        <!-- ── Network info ─────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvLanIp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:text="LAN IP: --"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvEndpoint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="Endpoint: --"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ── Section divider ──────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ── Tags header ──────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvTagsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:letterSpacing="0.08"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:text="@string/label_active_tags"
        android:textAllCaps="true"
        android:textColor="@color/primary"
        android:textSize="13sp" />

    <!-- ── Empty state ──────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvNoTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="32dp"
        android:text="@string/label_no_tags"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="visible" />

    <!-- ── Tag list ─────────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTags"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>

        android:fillColor="#FFFFFF"
        android:pathData="
        M 18,62
        C 16,56 18,50 22,44
        C 28,36 38,30 48,26
        C 52,24 56,21 60,18
        L 64,9
        L 71,19
        C 76,25 82,33 84,44
        C 86,56 83,66 77,75
        C 71,83 60,86 50,84
        C 38,82 27,74 22,68
        C 20,65 18,63 18,62 Z
